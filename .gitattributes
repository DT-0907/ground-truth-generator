# Store Windows scripts with CRLF bytes VERBATIM. `-text` = no EOL
# normalization, so the committed CRLF bytes are kept for BOTH `git clone`
# AND GitHub ZIP downloads. (The previous `text eol=crlf` stored LF in the
# blob and only converted on checkout, so ZIP downloads got LF — which makes
# cmd.exe parse-fail and the build window flash open/closed instantly.)
*.bat       -text
*.cmd       -text

# Shell scripts and most source must stay LF.
*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.txt       text eol=lf

# Inno Setup scripts are Windows-only — keep CRLF bytes verbatim too.
*.iss       -text

# Binary — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.icns      binary
*.pt        binary
*.dmg       binary
*.zip       binary
*.mp4       binary
*.mov       binary
*.avi       binary
*.mkv       binary
